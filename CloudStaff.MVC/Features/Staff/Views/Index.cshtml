@model IEnumerable<CloudStaff.MVC.Features.Staff.StaffViewModel>
@{
    ViewData["Title"] = "Staff";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Staff</h1>
    <a asp-action="Create" class="btn btn-primary">Add Staff</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>AS Number</th>
            <th>Manager</th>
            <th>Home Pool</th>
            <th>Role</th>
            <th>GCM</th>
            <th>SFIA</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Name</td>
                <td>@s.AsNumber</td>
                <td>@s.ManagerName</td>
                <td>@s.HomePoolName</td>
                <td>@s.StaffRoleName</td>
                <td>@s.GcmLevel</td>
                <td>@s.SfiaLevel</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
