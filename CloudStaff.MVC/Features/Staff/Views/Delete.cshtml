@model CloudStaff.MVC.Features.Staff.StaffViewModel
@{
    ViewData["Title"] = "Delete Staff";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="h3 mb-4">Delete Staff</h1>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <asp-validation-summary asp-validation-summary="All" />
            </div>
        }

        <dl class="row mb-4">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>
            <dt class="col-sm-4">AS Number</dt>
            <dd class="col-sm-8">@Model.AsNumber</dd>
            <dt class="col-sm-4">Manager</dt>
            <dd class="col-sm-8">@Model.ManagerName</dd>
            <dt class="col-sm-4">Home Pool</dt>
            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.HomePoolName) ? "—" : Model.HomePoolName)</dd>
            <dt class="col-sm-4">Role</dt>
            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.StaffRoleName) ? "—" : Model.StaffRoleName)</dd>
            <dt class="col-sm-4">GCM Level</dt>
            <dd class="col-sm-8">@(Model.GcmLevel?.ToString() ?? "—")</dd>
            <dt class="col-sm-4">SFIA Level</dt>
            <dd class="col-sm-8">@(Model.SfiaLevel?.ToString() ?? "—")</dd>
            @if (!string.IsNullOrEmpty(Model.ContractJobTitle))
            {
                <dt class="col-sm-4">Contract Job Title</dt>
                <dd class="col-sm-8">@Model.ContractJobTitle</dd>
            }
            @if (Model.PlatformNames.Any())
            {
                <dt class="col-sm-4">Platforms</dt>
                <dd class="col-sm-8">@string.Join(", ", Model.PlatformNames)</dd>
            }
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
