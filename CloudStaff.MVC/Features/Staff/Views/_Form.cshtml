@model CloudStaff.MVC.Features.Staff.StaffViewModel

<div class="mb-3">
    <label asp-for="Name" class="form-label"></label>
    <input asp-for="Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="AsNumber" class="form-label"></label>
    <input asp-for="AsNumber" class="form-control" />
    <span asp-validation-for="AsNumber" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="ManagerId" class="form-label"></label>
    <select asp-for="ManagerId" asp-items="ViewBag.Managers" class="form-select">
        <option value="">-- Select Manager --</option>
    </select>
    <span asp-validation-for="ManagerId" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="HomePoolId" class="form-label"></label>
    <select asp-for="HomePoolId" asp-items="ViewBag.HomePools" class="form-select" id="HomePoolId">
        <option value="">-- Select Home Pool --</option>
    </select>
    <span asp-validation-for="HomePoolId" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="StaffRoleId" class="form-label"></label>
    <select asp-for="StaffRoleId" asp-items="ViewBag.StaffRoles" class="form-select" id="StaffRoleId">
        <option value="">-- Select Role --</option>
    </select>
    <span asp-validation-for="StaffRoleId" class="text-danger small"></span>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="GcmLevel" class="form-label"></label>
        <select asp-for="GcmLevel" class="form-select">
            <option value="">--</option>
            @for (int i = 1; i <= 9; i++)
            {
                <option value="@i" selected="@(Model.GcmLevel == i ? "selected" : null)">@i</option>
            }
        </select>
        <span asp-validation-for="GcmLevel" class="text-danger small"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label asp-for="SfiaLevel" class="form-label"></label>
        <select asp-for="SfiaLevel" class="form-select">
            <option value="">--</option>
            @for (int i = 1; i <= 7; i++)
            {
                <option value="@i" selected="@(Model.SfiaLevel == i ? "selected" : null)">@i</option>
            }
        </select>
        <span asp-validation-for="SfiaLevel" class="text-danger small"></span>
    </div>
</div>

<div class="mb-3">
    <label asp-for="ContractJobTitle" class="form-label"></label>
    <input asp-for="ContractJobTitle" class="form-control" />
    <span asp-validation-for="ContractJobTitle" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label class="form-label">Platforms</label>
    <div class="d-flex flex-wrap gap-3">
        @{
            var allPlatforms = ViewBag.Platforms as IEnumerable<CloudStaff.EntityModels.Platform> ?? [];
        }
        @foreach (var platform in allPlatforms)
        {
            var isChecked = Model.PlatformIds.Contains(platform.Id);
            <div class="form-check">
                <input class="form-check-input" type="checkbox"
                       name="PlatformIds" value="@platform.Id"
                       id="platform_@platform.Id"
                       @(isChecked ? "checked" : "") />
                <label class="form-check-label" for="platform_@platform.Id">@platform.Name</label>
            </div>
        }
    </div>
</div>

<script>
    document.getElementById('HomePoolId').addEventListener('change', async function () {
        const homePoolId = this.value;
        const roleSelect = document.getElementById('StaffRoleId');

        // Clear existing options
        roleSelect.innerHTML = '<option value="">-- Select Role --</option>';

        if (!homePoolId) return;

        const response = await fetch(`/Staff/GetRolesByPool?homePoolId=${homePoolId}`);
        const roles = await response.json();
        roles.forEach(r => {
            const opt = document.createElement('option');
            opt.value = r.id;
            opt.textContent = r.title;
            roleSelect.appendChild(opt);
        });
    });
</script>
