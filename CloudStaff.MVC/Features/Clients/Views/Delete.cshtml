@model CloudStaff.MVC.Features.Clients.ClientViewModel
@using CloudStaff.EntityModels
@{
    ViewData["Title"] = "Delete Client";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="h3 mb-4">Delete Client</h1>

        @if (Model.ProjectCount > 0)
        {
            <div class="alert alert-warning">
                This client has <strong>@Model.ProjectCount</strong> project(s) which will also be permanently deleted.
            </div>
        }

        <dl class="row mb-4">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Type == ClientType.Internal ? "bg-secondary" : "bg-primary")">@Model.Type</span>
            </dd>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>
            }
            <dt class="col-sm-3">Projects</dt>
            <dd class="col-sm-9">@Model.ProjectCount</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
