@model CloudStaff.MVC.Features.Managers.ManagerViewModel
@{
    ViewData["Title"] = "Delete Manager";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="h3 mb-4">Delete Manager</h1>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <asp-validation-summary asp-validation-summary="All" />
            </div>
        }

        @if (Model.StaffCount > 0)
        {
            <div class="alert alert-warning">
                This manager has <strong>@Model.StaffCount</strong> staff assigned.
                Reassign them before deleting.
            </div>
        }

        <dl class="row mb-4">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">AS Number</dt>
            <dd class="col-sm-9">@Model.AsNumber</dd>
            <dt class="col-sm-3">Location</dt>
            <dd class="col-sm-9">@Model.Location</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger"
                    @(Model.StaffCount > 0 ? "disabled" : "")>
                    Delete
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
