@model IEnumerable<CloudStaff.MVC.Features.Managers.ManagerViewModel>
@{
    ViewData["Title"] = "Managers";
}



<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Managers</h1>
    <a asp-action="Create" class="btn btn-primary">Add Manager</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>AS Number</th>
            <th>Location</th>
            <th>Email</th>
            <th>Staff</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.Name</td>
                <td>@m.AsNumber</td>
                <td>@m.Location</td>
                <td>@m.Email</td>
                <td>@m.StaffCount</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>